// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Core Tenant & User Management
// ============================================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  status    String   @default("active") // active, suspended
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  connectors            Connector[]
  processTemplates      ProcessTemplate[]
  processDrafts         ProcessDraft[]
  submissions           Submission[]
  auditLogs             AuditLog[]
  bootstrapJobs         BootstrapJob[]
  parseTasks            ParseTask[]
  permissionPolicies    PermissionPolicy[]
  chatSessions          ChatSession[]
  mcpTools              MCPTool[]
  apiUploadJobs         ApiUploadJob[]
  parseJobs             ParseJob[]
  connectorSecretRefs   ConnectorSecretRef[]
  authBindings          AuthBinding[]
  authSessionAssets     AuthSessionAsset[]
  delegatedCredentials  UserDelegatedCredential[]
  connectorCapabilities ConnectorCapability[]
  remoteProcesses       RemoteProcess[]
  syncCursors           SyncCursor[]
  syncJobs              SyncJob[]
  submissionEvents      SubmissionEvent[]
  referenceDatasets     ReferenceDataset[]
  webhookInboxes        WebhookInbox[]

  @@map("tenants")
}

model User {
  id          String   @id @default(uuid())
  tenantId    String
  username    String
  email       String
  displayName String
  roles       Json // ["admin", "flow_manager", "user", "auditor"]
  oaUserId    String? // OA系统中的用户ID
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  drafts       ProcessDraft[]
  submissions  Submission[]
  chatSessions ChatSession[]
  authBindings AuthBinding[]
  delegatedCredentials UserDelegatedCredential[]

  @@unique([tenantId, username])
  @@unique([tenantId, email])
  @@map("users")
}

// ============================================================
// Bootstrap Center (Batch 0 - Highest Priority)
// ============================================================

model BootstrapJob {
  id              String    @id @default(uuid())
  tenantId        String
  connectorId     String?   // 发布后关联的连接器，删除连接器时置空
  name            String?
  status          String    @default("CREATED") // CREATED -> DISCOVERING -> PARSING -> AUTH_PROBING -> VALIDATING -> SELF_HEALING -> REVALIDATING -> NORMALIZING -> COMPILING -> PUBLISHED / PARTIALLY_PUBLISHED / VALIDATION_FAILED / FAILED / CONNECTOR_DELETED
  queueJobId      String?
  currentStage    String?
  stageStartedAt  DateTime?
  lastHeartbeatAt DateTime?
  recoveryAttemptCount  Int       @default(0)
  reconcileAttemptCount Int       @default(0)
  stalledReason   String?   @db.Text
  lastError       String?   @db.Text
  oaUrl           String?
  authConfig      Json?     // 用户填写的认证信息 { authType, username, password, token, headerName, loginPath, appKey, appSecret, ... }
  sourceBundleUrl String?
  openApiUrl      String?
  harFileUrl      String?
  uploadedFiles   Json? // Array of file paths
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  connector     Connector?        @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  sources       BootstrapSource[]
  reports       BootstrapReport[]
  flowIRs       FlowIR[]
  fieldIRs      FieldIR[]
  ruleIRs       RuleIR[]
  permissionIRs PermissionIR[]
  adapterBuilds AdapterBuild[]
  repairAttempts BootstrapRepairAttempt[]
  replayCases   ReplayCase[]
  driftEvents   DriftEvent[]
  parseJobs     ParseJob[]

  @@index([tenantId, status])
  @@index([connectorId])
  @@index([queueJobId])
  @@index([status, lastHeartbeatAt])
  @@map("bootstrap_jobs")
}

model BootstrapSource {
  id             String   @id @default(uuid())
  bootstrapJobId String
  sourceType     String // oa_url, source_bundle, openapi, har, file
  sourceUrl      String?
  sourceContent  String?  @db.Text // For inline content
  metadata       Json? // Additional metadata
  createdAt      DateTime @default(now())

  bootstrapJob BootstrapJob @relation(fields: [bootstrapJobId], references: [id], onDelete: Cascade)

  @@map("bootstrap_sources")
}

model BootstrapReport {
  id             String   @id @default(uuid())
  bootstrapJobId String
  oclLevel       String // OCL0-OCL5
  coverage       Float // 0.0-1.0
  confidence     Float // 0.0-1.0
  risk           String // low, medium, high
  evidence       Json // Array of evidence items
  recommendation String   @db.Text
  createdAt      DateTime @default(now())

  bootstrapJob BootstrapJob @relation(fields: [bootstrapJobId], references: [id], onDelete: Cascade)

  @@map("bootstrap_reports")
}

model BootstrapRepairAttempt {
  id             String   @id @default(uuid())
  bootstrapJobId String
  flowCode       String
  attemptNo      Int
  triggerReason  String
  status         String // fixed, failed, skipped, rejected
  confidence     Float?
  proposedPatch  Json?
  appliedPatch   Json?
  result         Json?
  errorMessage   String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bootstrapJob BootstrapJob @relation(fields: [bootstrapJobId], references: [id], onDelete: Cascade)

  @@unique([bootstrapJobId, flowCode, attemptNo])
  @@index([bootstrapJobId, flowCode])
  @@map("bootstrap_repair_attempts")
}

// ============================================================
// Intermediate Representation (IR) - For OA Normalization
// ============================================================

model FlowIR {
  id             String   @id @default(uuid())
  bootstrapJobId String
  flowCode       String
  flowName       String
  flowCategory   String?
  entryUrl       String?
  submitUrl      String?
  queryUrl       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  bootstrapJob BootstrapJob @relation(fields: [bootstrapJobId], references: [id], onDelete: Cascade)

  @@unique([bootstrapJobId, flowCode])
  @@map("flow_irs")
}

model FieldIR {
  id             String   @id @default(uuid())
  bootstrapJobId String
  flowCode       String
  fieldKey       String
  fieldLabel     String
  fieldType      String // text, number, date, select, file, etc.
  required       Boolean  @default(false)
  defaultValue   String?
  options        Json? // For select/radio fields
  validation     Json? // Validation rules
  metadata       Json?
  createdAt      DateTime @default(now())

  bootstrapJob BootstrapJob @relation(fields: [bootstrapJobId], references: [id], onDelete: Cascade)

  @@unique([bootstrapJobId, flowCode, fieldKey])
  @@map("field_irs")
}

model RuleIR {
  id             String   @id @default(uuid())
  bootstrapJobId String
  flowCode       String
  ruleType       String // validation, calculation, conditional
  ruleExpression String   @db.Text
  errorLevel     String // error, warn
  errorMessage   String?
  metadata       Json?
  createdAt      DateTime @default(now())

  bootstrapJob BootstrapJob @relation(fields: [bootstrapJobId], references: [id], onDelete: Cascade)

  @@map("rule_irs")
}

model PermissionIR {
  id             String   @id @default(uuid())
  bootstrapJobId String
  flowCode       String
  permissionType String // role, department, custom
  permissionRule String   @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())

  bootstrapJob BootstrapJob @relation(fields: [bootstrapJobId], references: [id], onDelete: Cascade)

  @@map("permission_irs")
}

// ============================================================
// Adapter Compilation & Replay Validation
// ============================================================

model AdapterBuild {
  id             String   @id @default(uuid())
  bootstrapJobId String
  adapterType    String // api, rpa, hybrid
  generatedCode  String   @db.Text
  buildStatus    String // pending, success, failed
  buildLog       String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bootstrapJob BootstrapJob @relation(fields: [bootstrapJobId], references: [id], onDelete: Cascade)

  @@map("adapter_builds")
}

model ReplayCase {
  id             String   @id @default(uuid())
  bootstrapJobId String
  flowCode       String
  testData       Json
  expectedResult Json?
  createdAt      DateTime @default(now())

  bootstrapJob  BootstrapJob   @relation(fields: [bootstrapJobId], references: [id], onDelete: Cascade)
  replayResults ReplayResult[]

  @@map("replay_cases")
}

model ReplayResult {
  id           String   @id @default(uuid())
  replayCaseId String
  status       String // success, failed, error
  actualResult Json?
  errorMessage String?  @db.Text
  executedAt   DateTime @default(now())

  replayCase ReplayCase @relation(fields: [replayCaseId], references: [id], onDelete: Cascade)

  @@map("replay_results")
}

model DriftEvent {
  id             String   @id @default(uuid())
  bootstrapJobId String
  driftType      String // field_change, url_change, auth_change
  driftDetails   Json
  detectedAt     DateTime @default(now())
  resolved       Boolean  @default(false)

  bootstrapJob BootstrapJob @relation(fields: [bootstrapJobId], references: [id], onDelete: Cascade)

  @@map("drift_events")
}

// ============================================================
// Process Step & UI Action Graph (For Step-based OA)
// ============================================================

model ProcessStep {
  id         String   @id @default(uuid())
  flowCode   String
  stepOrder  Int
  stepName   String
  stepType   String // form, approval, notification
  stepConfig Json
  createdAt  DateTime @default(now())

  @@unique([flowCode, stepOrder])
  @@map("process_steps")
}

model UIActionGraph {
  id          String   @id @default(uuid())
  flowCode    String
  actionType  String // click, input, select, upload
  selector    String
  actionValue String?
  actionOrder Int
  metadata    Json?
  createdAt   DateTime @default(now())

  @@map("ui_action_graphs")
}

// ============================================================
// OA Connector Management
// ============================================================

model Connector {
  id              String    @id @default(uuid())
  tenantId        String
  name            String
  oaType          String // openapi, form-page, hybrid
  oaVendor        String? // 厂商名称
  oaVersion       String?
  baseUrl         String
  authType        String // oauth2, basic, apikey, cookie
  authConfig      Json // 认证配置
  healthCheckUrl  String?
  oclLevel        String // OCL0-OCL5
  falLevel        String? // F0-F4 (default level for this connector)
  status          String    @default("active")
  lastHealthCheck DateTime?
  syncStrategy    Json? // { primary, fallback, pollingIntervalMs, webhookRegisterToolName, statusQueryToolName, batchQueryToolName }
  statusMapping   Json? // { statusFieldPath, rules: [{ match, localStatus }], defaultStatus }
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant            Tenant               @relation(fields: [tenantId], references: [id])
  secretRef         ConnectorSecretRef?
  capability        ConnectorCapability?
  remoteProcesses   RemoteProcess[]
  syncCursors       SyncCursor[]
  syncJobs          SyncJob[]
  referenceDatasets ReferenceDataset[]
  webhookInboxes    WebhookInbox[]
  processTemplates  ProcessTemplate[]
  mcpTools          MCPTool[]
  apiUploadJobs     ApiUploadJob[]
  syncLogs          SyncLog[]
  bootstrapJobs     BootstrapJob[]
  authBindings      AuthBinding[]
  delegatedCredentials UserDelegatedCredential[]

  @@unique([tenantId, name])
  @@map("connectors")
}

model ConnectorSecretRef {
  id             String    @id @default(uuid())
  tenantId       String
  connectorId    String    @unique
  secretProvider String // vault, kms, env, manual
  secretPath     String // vault path / kms key alias
  secretVersion  String?
  rotationStatus String    @default("active")
  lastRotatedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("connector_secret_refs")
}

model AuthBinding {
  id           String    @id @default(uuid())
  tenantId     String
  connectorId  String
  userId       String?
  bindingName  String?
  ownerType    String    @default("user") // user, service
  authType     String // oauth2, basic, apikey, cookie
  authMode     String // password_bootstrap, api_token, cookie_session, browser_session, ticket_broker
  status       String    @default("active") // active, inactive, expired, revoked
  isDefault    Boolean   @default(false)
  lastBoundAt  DateTime?
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  connector    Connector          @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionAssets AuthSessionAsset[]

  @@index([tenantId, connectorId, status])
  @@index([tenantId, userId, status])
  @@index([connectorId, userId, isDefault])
  @@map("auth_bindings")
}

model AuthSessionAsset {
  id              String    @id @default(uuid())
  tenantId        String
  authBindingId   String
  assetType       String // auth_payload, api_token, cookie_session, browser_session, jump_ticket
  status          String    @default("active") // active, stale, expired, revoked
  encryptedPayload String   @db.Text
  issuedAt        DateTime?
  expiresAt       DateTime?
  lastValidatedAt DateTime?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  authBinding  AuthBinding @relation(fields: [authBindingId], references: [id], onDelete: Cascade)

  @@index([tenantId, authBindingId, status])
  @@index([authBindingId, assetType, status])
  @@map("auth_session_assets")
}

model UserDelegatedCredential {
  id                   String    @id @default(uuid())
  tenantId             String
  userId               String
  connectorId          String
  providerType         String
  subject              String?
  status               String    @default("active")
  encryptedAccessToken String?   @db.Text
  encryptedRefreshToken String?  @db.Text
  accessTokenExpiresAt DateTime?
  scope                String?
  metadata             Json?
  lastUsedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, connectorId])
  @@index([tenantId, userId, status])
  @@index([connectorId, status])
  @@map("user_delegated_credentials")
}

model ConnectorCapability {
  id                    String   @id @default(uuid())
  tenantId              String
  connectorId           String   @unique
  supportsDiscovery     Boolean  @default(false)
  supportsSchemaSync    Boolean  @default(false)
  supportsReferenceSync Boolean  @default(false)
  supportsStatusPull    Boolean  @default(false)
  supportsWebhook       Boolean  @default(false)
  supportsCancel        Boolean  @default(false)
  supportsUrge          Boolean  @default(false)
  supportsDelegate      Boolean  @default(false)
  supportsSupplement    Boolean  @default(false)
  supportsRealtimePerm  Boolean  @default(false)
  supportsIdempotency   Boolean  @default(false)
  syncModes             Json?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("connector_capabilities")
}

model RemoteProcess {
  id                String    @id @default(uuid())
  tenantId          String
  connectorId       String
  remoteProcessId   String
  remoteProcessCode String?
  remoteProcessName String
  processCategory   String?
  sourceVersion     String?
  sourceHash        String
  latestTemplateId  String?
  status            String    @default("active") // active, deprecated, disabled
  metadata          Json?
  discoveredAt      DateTime  @default(now())
  lastSchemaSyncAt  DateTime?
  lastDriftCheckAt  DateTime?

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  connector        Connector         @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  processTemplates ProcessTemplate[]

  @@unique([connectorId, remoteProcessId])
  @@index([tenantId, connectorId])
  @@index([sourceHash])
  @@map("remote_processes")
}

model ReferenceDataset {
  id            String    @id @default(uuid())
  tenantId      String
  connectorId   String
  datasetCode   String
  datasetName   String
  datasetType   String // department, user, dictionary, approver
  syncMode      String // ttl, full, incremental
  sourceHash    String?
  sourceVersion String?
  lastSyncedAt  DateTime?
  expiresAt     DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  connector Connector       @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  items     ReferenceItem[]

  @@unique([connectorId, datasetCode])
  @@index([tenantId, datasetType])
  @@map("reference_datasets")
}

model ReferenceItem {
  id           String   @id @default(uuid())
  datasetId    String
  remoteItemId String?
  itemKey      String
  itemLabel    String
  itemValue    String?
  parentKey    String?
  status       String   @default("active")
  payload      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dataset ReferenceDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId, itemKey])
  @@index([datasetId, remoteItemId])
  @@map("reference_items")
}

// ============================================================
// Process Library (流程库)
// ============================================================

model ProcessTemplate {
  id              String    @id @default(uuid())
  tenantId        String
  connectorId     String
  remoteProcessId String?
  processCode     String // 流程编码，如 "travel_expense"
  processName     String
  processCategory String? // 流程分类
  description     String?   @db.Text // 流程描述
  version         Int       @default(1)
  status          String    @default("draft") // draft, published, archived
  falLevel        String // F0-F4
  sourceHash      String?
  sourceVersion   String?
  reviewStatus    String    @default("approved") // draft, review, approved, rejected
  changeSummary   Json?
  supersedesId    String?
  schema          Json // 字段定义
  rules           Json? // 规则定义
  permissions     Json? // 权限定义
  uiHints         Json? // UI提示
  lastSyncedAt    DateTime?
  publishedAt     DateTime?
  publishedBy     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  connector     Connector         @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  remoteProcess RemoteProcess?    @relation(fields: [remoteProcessId], references: [id], onDelete: SetNull)
  supersedes    ProcessTemplate?  @relation("ProcessTemplateSupersedes", fields: [supersedesId], references: [id])
  supersededBy  ProcessTemplate[] @relation("ProcessTemplateSupersedes")
  drafts        ProcessDraft[]
  submissions   Submission[]

  @@unique([connectorId, processCode, version])
  @@index([tenantId, status])
  @@index([connectorId, remoteProcessId, version])
  @@map("process_templates")
}

// ============================================================
// Parse Task (解析任务)
// ============================================================

model ParseTask {
  id          String    @id @default(uuid())
  tenantId    String
  sourceType  String // openapi, har, manual
  sourceUrl   String?
  sourceData  Json?
  status      String    @default("pending") // pending, parsing, completed, failed
  result      Json?
  errorMsg    String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("parse_tasks")
}

// ============================================================
// Permission Management
// ============================================================

model PermissionPolicy {
  id          String   @id @default(uuid())
  tenantId    String
  processCode String
  policyType  String // rbac, abac
  policyRule  Json // 策略规则
  priority    Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, processCode])
  @@map("permission_policies")
}

// ============================================================
// Chat & Assistant
// ============================================================

model ChatSession {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  status    String   @default("active") // active, closed
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  user     User          @relation(fields: [userId], references: [id])
  messages ChatMessage[]
  attachmentBindings AttachmentBinding[]

  @@index([tenantId, userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String // user, assistant, system
  content   String   @db.Text
  metadata  Json? // intent, extracted_fields, etc.
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

// ============================================================
// Process Draft (草稿)
// ============================================================

model ProcessDraft {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  templateId String
  sessionId  String? // 关联的对话会话
  formData   Json
  status     String   @default("editing") // editing, ready, submitted
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  user     User            @relation(fields: [userId], references: [id])
  template ProcessTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  attachmentBindings AttachmentBinding[]

  @@index([tenantId, userId])
  @@map("process_drafts")
}

// ============================================================
// Submission (提交记录)
// ============================================================

model Submission {
  id             String    @id @default(uuid())
  tenantId       String
  userId         String
  templateId     String
  draftId        String?
  idempotencyKey String
  formData       Json
  oaSubmissionId String? // OA系统返回的单据ID
  status         String    @default("pending") // pending, submitted, in_progress, approved, rejected, failed, cancelled, completed
  submitResult   Json?
  errorMsg       String?   @db.Text
  submittedAt    DateTime?
  lastSyncedAt   DateTime? // 上次同步时间
  syncFailCount  Int       @default(0) // 连续同步失败次数
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  user          User               @relation(fields: [userId], references: [id])
  template      ProcessTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  statusRecords SubmissionStatus[]
  events        SubmissionEvent[]
  attachmentBindings AttachmentBinding[]

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, userId])
  @@index([tenantId, oaSubmissionId])
  @@index([tenantId, templateId, status])
  @@map("submissions")
}

model SubmissionStatus {
  id           String   @id @default(uuid())
  submissionId String
  status       String
  statusDetail Json?
  queriedAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_statuses")
}

model SubmissionEvent {
  id            String   @id @default(uuid())
  tenantId      String
  submissionId  String
  eventType     String // submitted, accepted, in_progress, approved, rejected, cancelled, supplemented
  eventSource   String // oa_pull, oa_webhook, user_action, internal
  remoteEventId String?
  eventTime     DateTime
  status        String
  payload       Json?
  createdAt     DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, eventSource, remoteEventId])
  @@index([tenantId, status])
  @@index([submissionId, eventTime])
  @@map("submission_events")
}

model AttachmentAsset {
  id            String   @id @default(uuid())
  tenantId      String
  uploaderId    String
  storageType   String   @default("local")
  storageKey    String
  originalName  String
  extension     String?
  mimeType      String
  size          Int
  sha256        String?
  status        String   @default("uploaded") // uploaded, deleted
  previewStatus String   @default("none") // none, pending, ready, failed, unsupported
  previewKey    String?
  previewError  String?  @db.Text
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bindings AttachmentBinding[]

  @@index([tenantId, uploaderId])
  @@index([tenantId, status])
  @@map("attachment_assets")
}

model AttachmentBinding {
  id           String   @id @default(uuid())
  tenantId     String
  assetId      String
  sessionId    String?
  draftId      String?
  submissionId String?
  fieldKey     String?
  bindScope    String // field, general
  phase        String // draft, submit, supplement, rework, history
  versionNo    Int      @default(1)
  isActive     Boolean  @default(true)
  createdBy    String
  createdAt    DateTime @default(now())

  asset      AttachmentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  session    ChatSession?    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  draft      ProcessDraft?   @relation(fields: [draftId], references: [id], onDelete: Cascade)
  submission Submission?     @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([tenantId, assetId])
  @@index([tenantId, sessionId])
  @@index([tenantId, draftId])
  @@index([tenantId, submissionId])
  @@index([tenantId, fieldKey])
  @@map("attachment_bindings")
}

// ============================================================
// Audit Log (审计日志)
// ============================================================

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  traceId   String // 全链路追踪ID
  userId    String?
  action    String // chat, permission_check, submit, query_status, etc.
  resource  String? // 资源标识
  result    String // success, denied, error
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, traceId])
  @@index([tenantId, userId])
  @@index([tenantId, action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// MCP (Model Context Protocol) Tools
// ============================================================

model MCPTool {
  id          String @id @default(uuid())
  tenantId    String
  connectorId String

  // MCP 工具定义
  toolName        String // 工具名称，如 "o2oa_submit_expense"
  toolDescription String @db.Text // 工具描述
  toolSchema      Json // MCP 工具 schema（JSON Schema 格式）

  // API 映射
  apiEndpoint  String // API 端点，如 "/x_processplatform_assemble_surface/jaxrs/work"
  httpMethod   String // HTTP 方法，如 "POST"
  headers      Json? // 请求头模板
  bodyTemplate Json? // 请求体模板

  // 参数映射
  paramMapping Json // 参数映射规则：{ "targetParam": "sourceParam" } 或 { "targetParam": { "source": "sourceParam", "transform": "..." } }

  // 响应处理
  responseMapping Json // 响应映射规则：{ "targetField": "response.data.field" }

  // 元数据
  flowCode String? // 关联的流程代码
  category String // 工具分类：submit, query, cancel, urge, list, get, approve, status_query, batch_query, webhook_register, reference_data, auth_login, other
  enabled  Boolean @default(true)

  // 测试数据
  testInput  Json? // 测试输入示例
  testOutput Json? // 预期输出示例

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([connectorId, toolName])
  @@index([connectorId])
  @@index([flowCode])
  @@index([category])
  @@index([connectorId, category, enabled])
  @@map("mcp_tools")
}

// ============================================================
// API Document Parser (智能体API文档解析)
// ============================================================

model ApiUploadJob {
  id                      String   @id @default(uuid())
  tenantId                String
  connectorId             String
  sourceName              String?
  sourceHash              String
  sourceContent           String   @db.Text
  docType                 String
  oaUrl                   String?
  authConfig              Json?
  autoValidate            Boolean  @default(true)
  autoGenerateMcp         Boolean  @default(true)
  status                  String   @default("PENDING")
  currentAttemptNo        Int      @default(0)
  finalDecision           String?
  finalErrorType          String?
  finalErrorMessage       String?  @db.Text
  acceptedContent         String?  @db.Text
  acceptedContentHash     String?
  acceptedEndpointCount   Int?
  acceptedWorkflowCount   Int?
  acceptedValidationScore Float?
  uploadResult            Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  completedAt             DateTime?

  tenant    Tenant             @relation(fields: [tenantId], references: [id])
  connector Connector          @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  attempts  ApiUploadAttempt[]

  @@index([tenantId, connectorId])
  @@index([tenantId, status])
  @@map("api_upload_jobs")
}

model ApiUploadAttempt {
  id              String   @id @default(uuid())
  jobId           String
  attemptNo       Int
  stage           String
  strategy        String
  inputContent    String   @db.Text
  inputHash       String
  outputContent   String?  @db.Text
  outputHash      String?
  diagnostics     Json?
  repairActions   Json?
  parseSuccess    Boolean  @default(false)
  endpointCount   Int      @default(0)
  workflowCount   Int      @default(0)
  validationScore Float?
  decision        String
  errorType       String?
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  job ApiUploadJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, attemptNo])
  @@index([jobId, decision])
  @@map("api_upload_attempts")
}

model ParseJob {
  id             String       @id @default(uuid())
  tenantId       String
  bootstrapJobId String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  bootstrapJob   BootstrapJob @relation(fields: [bootstrapJobId], references: [id], onDelete: Cascade)

  documentType String // openapi/swagger/postman/har
  documentUrl  String?
  documentHash String // 文档内容哈希，用于缓存

  status   String // PENDING/PARSING/COMPLETED/FAILED/REVIEW_REQUIRED
  progress Int    @default(0)

  parseOptions  Json // 解析选项
  parseResult   Json? // 解析结果
  parseMetadata Json? // 元数据（耗时、token等）

  warnings Json @default("[]") // 警告信息
  errors   Json @default("[]") // 错误信息

  reviewedBy    String?
  reviewedAt    DateTime?
  reviewComment String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  extractedProcesses ExtractedProcess[]

  @@index([tenantId])
  @@index([bootstrapJobId])
  @@index([status])
  @@index([documentHash])
  @@map("parse_jobs")
}

model ExtractedProcess {
  id         String   @id @default(uuid())
  parseJobId String
  parseJob   ParseJob @relation(fields: [parseJobId], references: [id], onDelete: Cascade)

  processCode     String
  processName     String
  processCategory String
  description     String?

  confidence Float // 0-1
  endpoints  Json // API端点信息
  fields     Json // 字段定义

  status              String // EXTRACTED/REVIEWED/PUBLISHED/REJECTED
  publishedTemplateId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parseJobId])
  @@index([processCode])
  @@index([status])
  @@map("extracted_processes")
}

model SyncCursor {
  id            String    @id @default(uuid())
  tenantId      String
  connectorId   String
  syncDomain    String // schema, reference, status
  cursorType    String // watermark, token, etag, page
  cursorValue   String?   @db.Text
  lastVersion   String?
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([connectorId, syncDomain])
  @@index([tenantId, syncDomain])
  @@map("sync_cursors")
}

model SyncJob {
  id             String    @id @default(uuid())
  tenantId       String
  connectorId    String
  syncDomain     String // schema, reference, status
  triggerType    String // schedule, manual, webhook, repair
  status         String // pending, running, succeeded, failed, partial
  scope          Json?
  cursorSnapshot Json?
  result         Json?
  errorMessage   String?   @db.Text
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId, syncDomain, status])
  @@index([tenantId, createdAt])
  @@map("sync_jobs")
}

model WebhookInbox {
  id            String    @id @default(uuid())
  tenantId      String
  connectorId   String
  eventType     String?
  dedupeKey     String    @unique
  headers       Json?
  payload       Json
  receivedAt    DateTime  @default(now())
  processedAt   DateTime?
  processStatus String    @default("pending") // pending, processed, failed
  errorMessage  String?   @db.Text

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId, processStatus])
  @@map("webhook_inboxes")
}

// ============================================================
// Sync Log (同步日志)
// ============================================================

model SyncLog {
  id            String    @id @default(uuid())
  connectorId   String
  submissionId  String?
  syncType      String // webhook, polling, on_demand
  success       Boolean
  statusBefore  String?
  statusAfter   String?
  remoteRaw     Json?
  error         String?   @db.Text
  durationMs    Int?
  createdAt     DateTime  @default(now())

  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId, createdAt])
  @@index([submissionId])
  @@map("sync_logs")
}

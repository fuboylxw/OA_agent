{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@uniflow/shared-types": ["./packages/shared-types/src/index.ts"],
      "@uniflow/shared-schema": ["./packages/shared-schema/src"],
      "@uniflow/agent-kernel": ["./packages/agent-kernel/src"],
      "@uniflow/oa-adapters": ["./packages/oa-adapters/src"],
      "@uniflow/compat-engine": ["./packages/compat-engine/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next"]
}

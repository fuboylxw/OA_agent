{
  "openapi": "3.0.0",
  "info": {
    "title": "Mock OA API",
    "version": "1.0.0",
    "description": "OpenAPI specification for mock OA system"
  },
  "servers": [
    {
      "url": "http://localhost:8080/api"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/flows": {
      "get": {
        "summary": "List available flows",
        "responses": {
          "200": {
            "description": "List of flows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Flow"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/flows/{flowCode}/submit": {
      "post": {
        "summary": "Submit a flow",
        "parameters": [
          {
            "name": "flowCode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitResponse"
                }
              }
            }
          }
        }
      }
    },
    "/flows/{flowCode}/status/{submissionId}": {
      "get": {
        "summary": "Query submission status",
        "parameters": [
          {
            "name": "flowCode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "submissionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Submission status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "Flow": {
        "type": "object",
        "properties": {
          "flowCode": {
            "type": "string"
          },
          "flowName": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        }
      },
      "SubmitRequest": {
        "type": "object",
        "properties": {
          "formData": {
            "type": "object"
          },
          "idempotencyKey": {
            "type": "string"
          }
        }
      },
      "SubmitResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "submissionId": {
            "type": "string"
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "currentStep": {
            "type": "string"
          },
          "timeline": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  }
}

# =============================================================
# Database (PostgreSQL)
# =============================================================
DATABASE_URL="postgresql://uniflow:CHANGE_ME@localhost:5432/uniflow_oa?schema=public&connection_limit=20&pool_timeout=10"
POSTGRES_USER=uniflow
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=uniflow_oa

# =============================================================
# Redis
# =============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# =============================================================
# MinIO
# =============================================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=uniflow-attachments
MINIO_USE_SSL=false
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
ATTACHMENT_STORAGE_DRIVER=minio

# =============================================================
# API
# =============================================================
API_PORT=3001
API_HOST=0.0.0.0

# CORS — comma-separated list of allowed origins (e.g. http://localhost:3000)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Swagger — set to "true" to enable in production
ENABLE_SWAGGER=false

# =============================================================
# Worker
# =============================================================
WORKER_CONCURRENCY=5

# =============================================================
# Web
# =============================================================
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================
# Auth Session
# =============================================================
# REQUIRED in production — must be a random string >= 32 characters
AUTH_SESSION_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING
AUTH_BINDING_SECRET=
AUTH_SESSION_TTL_SECONDS=604800

# Password hashes — use scrypt format only:
#   "username": "scrypt$<salt>$<hash>"
# Generate with: node -e "const {scryptSync,randomBytes}=require('crypto');const s=randomBytes(16).toString('hex');console.log('scrypt$'+s+'$'+scryptSync(process.argv[1],s,64).toString('hex'))" YOUR_PASSWORD
AUTH_USER_PASSWORD_HASHES={}

# =============================================================
# LLM (for agents)
# =============================================================
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo-preview

# Legacy OpenAI env vars (also supported)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# =============================================================
# Tenant
# =============================================================
DEFAULT_TENANT_ID=default-tenant

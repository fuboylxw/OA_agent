# =============================================================
# Database (PostgreSQL)
# =============================================================
DATABASE_URL="postgresql://uniflow:CHANGE_ME@127.0.0.1:5432/uniflow_oa?schema=public&connection_limit=20&pool_timeout=10"
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_USER=uniflow
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=uniflow_oa

# =============================================================
# Redis
# =============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# =============================================================
# MinIO
# =============================================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=uniflow-attachments
MINIO_USE_SSL=false
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
ATTACHMENT_STORAGE_DRIVER=minio

# =============================================================
# API
# =============================================================
API_PORT=3001
API_HOST=0.0.0.0

# CORS — comma-separated list of allowed origins (e.g. http://localhost:3000)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Swagger — set to "true" to enable in production
ENABLE_SWAGGER=false

# =============================================================
# Worker
# =============================================================
WORKER_CONCURRENCY=5

# =============================================================
# Web
# =============================================================
# Leave blank in single-port deployment so browser uses the current origin.
NEXT_PUBLIC_API_URL=
INTERNAL_API_ORIGIN=http://127.0.0.1:3001
WEB_BIND_HOST=0.0.0.0

# Frontend auth mode: oauth2 only
NEXT_PUBLIC_AUTH_MODE=oauth2
NEXT_PUBLIC_AUTH_PROVIDER_NAME=统一认证

# =============================================================
# Unified OAuth2 SSO
# =============================================================
AUTH_MODE=oauth2
PUBLIC_WEB_BASE_URL=
AUTH_OAUTH2_BASE_URL=
AUTH_OAUTH2_CLIENT_ID=
AUTH_OAUTH2_CLIENT_SECRET=
AUTH_OAUTH2_PRIVATE_KEY=
AUTH_OAUTH2_SCOPE=client
AUTH_OAUTH2_REDIRECT_URI=
AUTH_OAUTH2_AUTHORIZE_URL=
AUTH_OAUTH2_TOKEN_URL=
AUTH_OAUTH2_USERINFO_URL=
AUTH_OAUTH2_LOGOUT_URL=
AUTH_OAUTH2_LOGOUT_REDIRECT_PARAMS=callback
AUTH_OAUTH2_STATE_SECRET=
AUTH_OAUTH2_ADMIN_USERNAMES=
AUTH_OAUTH2_ADMIN_USER_IDS=
AUTH_OAUTH2_FLOW_MANAGER_USERNAMES=
AUTH_OAUTH2_FLOW_MANAGER_USER_IDS=

# =============================================================
# Auth Session
# =============================================================
# REQUIRED in production — must be a random string >= 32 characters
AUTH_SESSION_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING
AUTH_BINDING_SECRET=
AUTH_SESSION_TTL_SECONDS=604800

# =============================================================
# LLM (for agents)
# =============================================================
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo-preview

# Legacy OpenAI env vars (also supported)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# =============================================================
# Tenant
# =============================================================
DEFAULT_TENANT_ID=default-tenant

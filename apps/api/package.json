{
  "name": "@uniflow/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "corepack pnpm exec nest start --watch",
    "build": "corepack pnpm exec nest build",
    "start": "node dist/main",
    "test": "corepack pnpm exec jest",
    "test:integration": "corepack pnpm exec jest --config jest.integration.config.js",
    "test:e2e": "corepack pnpm exec jest --config jest.e2e.config.js",
    "prisma": "corepack pnpm exec prisma",
    "prisma:generate": "corepack pnpm exec prisma generate --schema ../../prisma/schema.prisma",
    "prisma:migrate": "corepack pnpm exec prisma migrate dev --schema ../../prisma/schema.prisma",
    "prisma:seed": "corepack pnpm exec tsx ../../prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@nestjs/bull": "^10.0.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "@uniflow/agent-kernel": "workspace:*",
    "@uniflow/compat-engine": "workspace:*",
    "@uniflow/oa-adapters": "workspace:*",
    "@uniflow/shared-schema": "workspace:*",
    "@uniflow/shared-types": "workspace:*",
    "axios": "^1.6.5",
    "body-parser": "^2.2.2",
    "bull": "^4.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "playwright": "^1.58.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "prisma": "^5.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "webpack": "^5.105.3"
  }
}

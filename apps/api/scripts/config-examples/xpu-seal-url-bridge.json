                "target": { "id": "field0056_id" }
              },
              {
                "fieldKey": "sealTypes",
                "fieldType": "checkbox",
                "sources": ["sealTypes", "用印类型"],
                "options": [{ "label": "单位介绍信", "value": "单位介绍信" }],
                "target": { "id": "field0057_id" }
              },
              {
                "fieldKey": "sealTypes",
                "fieldType": "checkbox",
                "sources": ["sealTypes", "用印类型"],
                "options": [{ "label": "事业单位法人证书", "value": "事业单位法人证书" }],
                "target": { "id": "field0058_id" }
              },
              {
                "fieldKey": "sealTypes",
                "fieldType": "checkbox",
                "sources": ["sealTypes", "用印类型"],
                "options": [{ "label": "校学术委员会主任章", "value": "校学术委员会主任章" }],
                "target": { "id": "field0059_id" }
              },
              {
                "fieldKey": "sealTypes",
                "fieldType": "checkbox",
                "sources": ["sealTypes", "用印类型"],
                "options": [{ "label": "法人身份证复印件", "value": "法人身份证复印件" }],
                "target": { "id": "field0060_id" }
